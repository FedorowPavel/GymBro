# Telegram (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ALLOWED_USER_IDS=123456789

# Cursor — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_...
CURSOR_MODEL=auto

# Max seconds to wait for agent reply (default 300 = 5 min)
AGENT_ASK_TIMEOUT_SECONDS=300

# local = Mac + Cursor; cloud = Railway etc.
AGENT_RUNTIME=local
CURSOR_CLOUD_REPO_URL=https://github.com/FedorowPavel/gym-bro

# Optional: override client profile path
CLIENT_PROFILE_PATH=
